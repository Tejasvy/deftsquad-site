# Copy to .env.local and fill in. Do NOT commit .env.local.
# Create a key at https://resend.com/api-keys (free: 100/day, 3000/month).
RESEND_API_KEY=

# Address that receives form submissions.
CONTACT_TO_EMAIL=

# "From" used by Resend. For testing, use the shared sandbox sender:
#   DeftSquad <onboarding@resend.dev>
# For production, replace with a verified domain sender.
CONTACT_FROM_EMAIL="DeftSquad <onboarding@resend.dev>"
